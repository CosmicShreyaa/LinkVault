# MongoDB connection string (Atlas or local), e.g.
# mongodb+srv://user:pass@cluster.mongodb.net or mongodb://localhost:27017
MONGODB_URI=
MONGODB_DB=linkvault

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=

# Port for the local Express dev server (api/server.js)
PORT=4000

# Base URL the frontend uses to reach the API in local dev, since the Vite
# dev server (port 8080) and the Express dev server (port 4000) run
# separately. Leave unset in production — same-origin "/api" is used instead.
VITE_API_URL=http://localhost:4000/api
